# ---------------------------------------------------------------------------
# Emarath Backend — environment template
# Copy this file to `.env` (or `.env.<environment>`) and adjust as needed.
# Do NOT commit real secrets. This file contains non-secret defaults only.
# ---------------------------------------------------------------------------

# Application environment: development | staging | production
# Selects the configuration without any code change. On Render this is set as
# a real environment variable per service.
NODE_ENV=development

# Port the HTTP server listens on.
# Locally this is 5000. On Render, the platform injects PORT automatically.
PORT=5000

# Human-readable service name (shown in the health check response).
APP_NAME=Emarath Backend

# Global API route prefix. The health check is served at /<API_PREFIX>/health.
API_PREFIX=api

# Allowed CORS origin (the Emarath frontend URL).
CORS_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# Database (PostgreSQL) — FND-01.2
# Provide these per environment (dev/staging/production) as real, secret
# values. NEVER commit real credentials; only this placeholder template is
# tracked. On Neon, both a pooled and a direct (unpooled) URL are provided.
# ---------------------------------------------------------------------------

# Pooled connection — used by the running application (runtime queries).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# Direct/unpooled connection — used by Prisma CLI migration operations
# (prisma migrate / db execute). On Neon this is the non-pooler host.
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@DIRECT_HOST:5432/DBNAME?sslmode=require"
