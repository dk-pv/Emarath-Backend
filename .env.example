# ---------------------------------------------------------------------------
# Emarath Backend — environment template
# Copy this file to `.env` (or `.env.<environment>`) and adjust as needed.
# Do NOT commit real secrets. This file contains non-secret defaults only.
# ---------------------------------------------------------------------------

# Application environment: development | staging | production
# Selects the configuration without any code change. On Render this is set as
# a real environment variable per service.
NODE_ENV=development

# Port the HTTP server listens on.
# Locally this is 5000. On Render, the platform injects PORT automatically.
PORT=5000

# Human-readable service name (shown in the health check response).
APP_NAME=Emarath Backend

# Global API route prefix. The health check is served at /<API_PREFIX>/health.
API_PREFIX=api

# Allowed CORS origin (the Emarath frontend URL).
CORS_ORIGIN=http://localhost:3000
