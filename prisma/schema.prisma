// Emarath — Prisma schema (FND-01.2: Core database setup & conventions)
// Docs: https://pris.ly/d/prisma-schema
//
// Shared field conventions (every future model MUST follow these):
//   id         String   @id @default(uuid()) @db.Uuid   -> column "id"
//   createdAt  DateTime @default(now())      @map("created_at")
//   updatedAt  DateTime @updatedAt           @map("updated_at")
//   deletedAt  DateTime?                     @map("deleted_at")  // soft-delete, where needed
//
// Naming: PascalCase models / camelCase fields in Prisma; snake_case tables &
// columns in PostgreSQL via @@map / @map. See README "Database conventions".

generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  runtime             = "nodejs"
  moduleFormat        = "cjs"
  importFileExtension = "js"
}

datasource db {
  provider = "postgresql"
}

// Migration history proves the tooling round-trip required by FND-01.2 AC2:
//   20260715115025_init                 -> created "migration_check"
//   <ts>_drop_migration_check           -> rolled it back (reverse migration)
// The convention-check model was temporary scaffolding, never a domain entity,
// and held no application data.

/// The five user types the platform is built around (AUTH-01.1). Fixed by the
/// backlog rather than configurable — role administration is explicitly out of
/// scope — so an enum is the honest model.
enum UserRole {
  SUPERADMIN
  SALES_MANAGER
  SALES_AGENT
  CUSTOMER_SERVICE_AGENT
  MARKETING_ANALYST
}

/// Minimum slice of AUTH-01.1 needed for LEAD-01.1 AC4 (multi-agent assignment).
/// AUTH-01.1 is NOT complete here: credentials, hashing and login are its own
/// task and add to this model rather than reshape it.
model User {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(120)
  email     String    @unique @db.VarChar(180)
  role      UserRole
  /// Team association, used later for role scoping (AUTH-01.1 AC1/AC3).
  team      String?   @db.VarChar(120)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  assignments     LeadAssignment[]
  importJobs      ImportJob[]
  viewPreferences UserViewPreference[]

  @@map("users")
}

/// Core lead record (LEAD-01.1).
///
/// Optionality mirrors what Workpex marks required in the New Lead drawer
/// (`leads-add-new-lead-drawer-scroll-1-top.png`): Customer Name, Primary Phone
/// and Lead Status carry an asterisk; everything else is blank on real rows in
/// `leads-list-default-scroll-left-assigned-avatar-tooltip.png`.
///
/// Order, delivery, tags, complaint and outreach fields are deliberately absent:
/// they are LEAD-01.2 and LEAD-01.3, each with its own migration.
model Lead {
  id String @id @default(uuid()) @db.Uuid

  /// "Customer Name" in Workpex — the display name, not a person's given name.
  name           String  @db.VarChar(180)
  firstName      String? @map("first_name") @db.VarChar(120)
  primaryPhone   String  @map("primary_phone") @db.VarChar(32)
  secondaryPhone String? @map("secondary_phone") @db.VarChar(32)
  language       String? @db.VarChar(64)
  country        String? @db.VarChar(64)

  /// Origin channel (Workpex: DoubleTick, Broadcast, …).
  source String? @db.VarChar(64)

  /// LEAD-01.1 AC3: status and pipeline stage are ONE field. Workpex proves it —
  /// the Kanban columns in `kanban-board-default-legend-tooltip-converted.png`
  /// (New, Initial Contact, SUPER HOT, HOT, Cold, Warm) are the same values the
  /// card badges and the list's Lead Status column show. Modelling them twice
  /// would let a lead sit in one column while claiming another status.
  ///
  /// A string, not an enum: Workpex users define their own statuses and colours,
  /// so new values must not require a migration. The reference table and colour
  /// mapping belong to FND-04.2 / LEAD-11.1.
  status String @db.VarChar(64)

  /// LEAD-06.2 (ADR-0005): the pipeline/board a lead is routed to — Workpex values
  /// "Lead Pipeline", "Complaints", "LOGISTICS", "QC". This is a SEPARATE axis from
  /// `status`: status is the stage within a pipeline (New/HOT/WON — the Kanban
  /// columns), pipeline is the board the lead belongs to. The New Lead drawer and
  /// the list both show Lead Status and Lead Pipeline as distinct fields, so the
  /// original single-field assumption was incomplete. A configurable string like
  /// status/source; options come from a lookup provider. Defaulted so the additive
  /// migration backfills existing rows and the Workpex form's default is matched.
  pipeline String @default("Lead Pipeline") @map("pipeline") @db.VarChar(64)

  // ── LEAD-01.2: order & delivery ────────────────────────────────────────────
  //
  // Every field here is nullable even though the New Lead drawer stars Product,
  // Actual Amount and Payment Method. Real Workpex rows contradict the form:
  // `leads-manage-columns-drawer-open.png` shows leads with an empty QTY, and
  // imported records arrive without commercial detail at all. "Required" is a
  // rule about the create form, so it lives in the DTO (LEAD-06.1); a NOT NULL
  // here would reject data Workpex demonstrably holds.

  /// Two fixed product slots, not a collection: Workpex offers exactly Product
  /// and Product 2, and the criterion caps it at two. A child table would model
  /// a list the product does not have.
  ///
  /// Quantities are decimal because Workpex renders them "1.00" in the QTY
  /// column — an integer would silently truncate a half-unit order.
  product      String?  @db.VarChar(180)
  productQty   Decimal? @map("product_qty") @db.Decimal(12, 2)
  /// Free text, unlike `product`, which is a dropdown. Workpex's own asymmetry.
  product2     String?  @db.VarChar(180)
  product2Qty  Decimal? @map("product2_qty") @db.Decimal(12, 2)

  /// Date only — Workpex captures no time of day for a booking.
  bookingDate DateTime? @map("booking_date") @db.Date
  category    String?   @db.VarChar(120)

  /// Confirmed vs expected value; both feed pipeline totals and revenue reports.
  /// Decimal, never float: AED totals must not drift on rounding.
  actualAmount     Decimal? @map("actual_amount") @db.Decimal(12, 2)
  forecastedAmount Decimal? @map("forecasted_amount") @db.Decimal(12, 2)

  /// A string, not an enum (AC3 asks only that values such as Cash on Delivery
  /// are supported); Workpex drives this from a configurable dropdown.
  paymentMethod String? @map("payment_method") @db.VarChar(64)

  /// Delivery address. `country` above completes it — the backlog puts country on
  /// the lead (LEAD-01.1 AC1) while Workpex draws it inside the Address section,
  /// so the field is shared rather than duplicated here.
  state        String? @db.VarChar(120)
  street       String? @db.VarChar(240)
  city         String? @db.VarChar(120)
  nationalCode String? @map("national_code") @db.VarChar(240)

  // ── LEAD-01.3: outreach ────────────────────────────────────────────────────

  /// Workpex values: Answered, No Response, Invalid Number. Nullable for the
  /// same reason as the fields above — real rows leave it blank.
  callStatus String? @map("call_status") @db.VarChar(64)

  /// Two counters, never one total: the criterion keeps call attempts and
  /// WhatsApp attempts separate, and Workpex columns them separately too.
  ///
  /// NOT NULL DEFAULT 0 per AC5. Workpex shows some cells blank, which would
  /// mean NULL; a counter that can be null forces every reader to treat absent
  /// and zero as the same thing, and the criterion is explicit that they default
  /// to zero. Recorded as a display difference rather than modelled as one.
  callAttempts     Int @default(0) @map("call_attempts")
  whatsappAttempts Int @default(0) @map("whatsapp_attempts")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  assignments LeadAssignment[]
  tags        LeadTag[]
  complaints  Complaint[]

  /// AC2: the fields the list and board filter and group by are indexed.
  /// Each is paired with deletedAt because every query must exclude soft-deleted
  /// rows, so that predicate is always present alongside them.
  @@index([status, deletedAt])
  @@index([source, deletedAt])
  @@index([pipeline, deletedAt])
  @@index([createdAt(sort: Desc)])
  /// LEAD-03.1: substring search on Customer Name and Primary Phone. `contains`
  /// compiles to ILIKE '%term%', whose leading wildcard a btree cannot use, so
  /// these are GIN trigram indexes (pg_trgm) — the index that makes an unanchored
  /// ILIKE fast at 15,000+ rows. Declared here so Prisma owns them and no drift
  /// results; the extension itself is enabled in the migration.
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([primaryPhone(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("leads")
}

/// Lead-to-agent assignment (LEAD-01.1 AC4). An explicit join rather than an
/// implicit m-n relation: Workpex shows an "Assigned Date" column, so the link
/// carries its own timestamp, which an implicit relation has nowhere to put.
model LeadAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  leadId    String   @map("lead_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  /// Doubles as Workpex's "Assigned Date" — the row is created when assigned.
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// An agent is assigned to a lead once or not at all.
  @@unique([leadId, userId])
  /// Drives "leads assigned to me", the agent's default view of the list.
  @@index([userId])
  @@map("lead_assignments")
}

/// A reusable tag (LEAD-01.3 AC1). Workpex shows them as chips on the lead row —
/// "QC VERIFIED" in `leads-list-all-rows-selected-bulk-action-bar.png`.
///
/// A table rather than a string array on the lead: LEAD-12.1 AC4 filters by tag,
/// which wants an indexed join, and renaming a tag should not mean rewriting
/// every lead that carries it.
model Tag {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique @db.VarChar(80)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  leads LeadTag[]

  @@map("tags")
}

/// Lead-to-tag link.
model LeadTag {
  id        String   @id @default(uuid()) @db.Uuid
  leadId    String   @map("lead_id") @db.Uuid
  tagId     String   @map("tag_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  /// LEAD-12.1 AC5: the same tag cannot be applied to a lead twice.
  @@unique([leadId, tagId])
  /// LEAD-12.1 AC4: "leads tagged X" reads from this side.
  @@index([tagId])
  @@map("lead_tags")
}

/// A complaint raised against a lead (LEAD-01.3 AC2).
///
/// An entity, not a column on the lead: LEAD-13.1 requires it to carry its own
/// details and a status to track handling, which a single dropdown value cannot.
/// One-to-many rather than one-to-one — Workpex's column is titled COMPLAINTS,
/// and a second complaint must not overwrite the first.
model Complaint {
  id      String @id @default(uuid()) @db.Uuid
  leadId  String @map("lead_id") @db.Uuid
  details String @db.Text

  /// Handling state (LEAD-13.1 AC4). A string for the same reason as lead
  /// status: the values are the business's to define, not a migration's.
  status String @db.VarChar(64)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  /// AC2: retrieving a lead's complaints is the only access path there is.
  @@index([leadId, deletedAt])
  @@map("complaints")
}

/// A bulk-import run (LEAD-07.1).
///
/// Persisted so progress can be polled while rows are written asynchronously, and
/// so the summary, the failed rows and the import history survive the request that
/// started the import. The row processing itself is not held here — only its
/// state — which keeps the table small regardless of file size.
///
/// `module` is a string, not an enum: the same engine imports Customers/Products/
/// Vendors later (the descriptor differs, the table does not), so a new module
/// must not force a migration — the same reason `status` on Lead is a string.
///
/// `errors` holds the standardized row-error objects
/// (`{ rowNumber, values, reason, errorCode }`) that back the downloadable error
/// report and the failed-row review. It is nullable — populated only once a row
/// fails — and lives inline rather than in a child table: at the 10 MB import cap
/// the failed set is bounded, and a second table would buy paging the review does
/// not need.
model ImportJob {
  id       String @id @default(uuid()) @db.Uuid
  module   String @db.VarChar(64)
  status   String @default("PENDING") @db.VarChar(24)
  fileName String @map("file_name") @db.VarChar(260)
  pipeline String @db.VarChar(64)

  /// The applied column → field mapping, kept as the run's audit trail.
  mapping Json

  totalRows     Int @default(0) @map("total_rows")
  processedRows Int @default(0) @map("processed_rows")
  importedCount Int @default(0) @map("imported_count")
  skippedCount  Int @default(0) @map("skipped_count")
  failedCount   Int @default(0) @map("failed_count")

  errors Json?

  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  /// The importer — drives history ("my imports") and the same role scoping the
  /// list uses. Nullable with `SetNull` so removing a user never destroys the
  /// import audit trail.
  createdById String? @map("created_by_id") @db.Uuid
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  /// History is "my recent imports, newest first".
  @@index([createdById, createdAt(sort: Desc)])
  @@map("import_jobs")
}

/// A saved per-user table layout — the Manage Columns result (LEAD-05.1 AC3).
///
/// Generic on purpose: `viewKey` names which table the layout is for ("leads"
/// today), so the same store backs the Activities and Kanban Manage Columns
/// drawers without a new table — the same reasoning that keeps `ImportJob.module`
/// a string. It is a user preference, not domain data: one row per user per view,
/// overwritten on Submit, so there is no soft delete (a reset just removes the row
/// and the default returns) — matching LeadAssignment/LeadTag, which also omit it.
///
/// `layout` holds `{ order: string[], hidden: string[] }` keyed by the frontend's
/// column ids. JSON, not columns, because the column set is the client's to define
/// (each entry carries render logic) and must be able to change without a
/// migration; the client reconciles stored keys against the live set on load, so a
/// renamed or new column never leaves a stale layout stuck.
model UserViewPreference {
  id      String @id @default(uuid()) @db.Uuid
  userId  String @map("user_id") @db.Uuid
  viewKey String @map("view_key") @db.VarChar(64)

  layout Json

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// One saved layout per user per view; the upsert target.
  @@unique([userId, viewKey])
  @@map("user_view_preferences")
}
